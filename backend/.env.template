# Tweet Alpha Tracker Configuration Template
# Copy this file to `.env` and fill in your actual credentials.

# The ID of the Twitter List to monitor
TWITTER_LIST_ID=your_twitter_list_id_here

# The xurl application name to use
XURL_APP_NAME=your_xurl_app_name_here

# xAI API Key for Grok sentiment analysis
XAI_API_KEY=your_xai_api_key_here

# Google Gemini API Key (Required if using Gemini models)
GEMINI_API_KEY=your_gemini_api_key_here

# Active LLM Model to use for analysis via LiteLLM
# E.g. xai/grok-4-1-fast-non-reasoning, gemini/gemini-2.5-flash
ACTIVE_MODEL=xai/grok-4-1-fast-non-reasoning

# Discord Webhook URL for buy/sell signal alerts
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Convex Deployment URL (e.g., https://your-project.convex.cloud)
CONVEX_URL=your_convex_url_here

# Backend Secret Key for Convex mutation protection (must match BACKEND_SECRET_KEY configured on Convex Dashboard)
BACKEND_SECRET_KEY=your_backend_secret_key_here
